# -----------------------------
# Leonidas / Leobot local state
# -----------------------------

# Local runtime config (DO NOT COMMIT)
config/config.json

# Runtime data (SQLite DB + WAL/SHM)
data/leonidas.db
data/*.db
data/*.db-wal
data/*.db-shm

# Optional: if you ever write state files/logs here
data/*.json
data/*.log

# Logs (if you log to files)
*.log
logs/
var/

# -----------------------------
# Python artifacts
# -----------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
*.so
*.egg-info/
build/
dist/
.eggs/

# Virtual environments
.venv/
venv/
env/

# Test / lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Editors / OS noise
.vscode/
.idea/
.DS_Store
Thumbs.db